<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.TodoListPage"
             x:Name="TodoPage"
             Title="TODOリスト">

    <!--
        このXAMLは「View」に相当し、MVVMにおいては
        - レイアウトの定義
        - バインド先（ViewModelのプロパティ・コマンド）の指定
        だけを担当する。
        DBやドメインロジックには直接触れない。
    -->

    <VerticalStackLayout
        Padding="20"
        Spacing="16">

        <Label
            Text="TODOリスト"
            FontSize="24"
            HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="8">
            <Entry
                Text="{Binding NewTitle}"
                Placeholder="やることを入力"
                HorizontalOptions="FillAndExpand" />

            <Button
                Text="追加"
                Command="{Binding AddCommand}" />
        </HorizontalStackLayout>

        <CollectionView
            ItemsSource="{Binding Todos}"
            Margin="0,10,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Stroke="#ccc"
                        StrokeThickness="1"
                        Padding="8"
                        Margin="0,0,0,8">
                        <HorizontalStackLayout
                            VerticalOptions="Center"
                            Spacing="8">
                            <Label
                                Text="{Binding Title}"
                                VerticalOptions="CenterAndExpand"
                                HorizontalOptions="StartAndExpand" />

                            <Button
                                Text="{Binding IsCompleted, Converter={StaticResource BoolToStatusTextConverter}}"
                                Command="{Binding BindingContext.ToggleCompletedCommand, Source={x:Reference TodoPage}}"
                                CommandParameter="{Binding .}" />

                            <Button
                                Text="削除"
                                TextColor="Red"
                                Command="{Binding BindingContext.DeleteCommand, Source={x:Reference TodoPage}}"
                                CommandParameter="{Binding .}" />
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>

