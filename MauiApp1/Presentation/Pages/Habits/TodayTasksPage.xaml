<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Presentation.Pages.Habits.TodayTasksPage"
             x:Name="TodayTasksPageRoot"
             Title="今日のタスク">

    <!--
        今日タスク画面（View）。
        MVVM ではレイアウトとバインド先の指定のみを行い、
        ロジックは TodayTasksViewModel に委ねる。
        - TodayItems: 今日やるべき習慣のチェックリスト
        - 各項目でチェックをトグルするボタンに ToggleCheckCommand をバインド
    -->

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label
            Text="今日やるべき習慣"
            FontSize="24"
            HorizontalOptions="Center" />

        <Label
            x:Name="DateLabel"
            Text="{Binding TargetDate, StringFormat='対象日: {0:yyyy/MM/dd}'}"
            FontSize="14"
            HorizontalOptions="Center"
            TextColor="Gray" />

        <!-- 進捗レポート画面への遷移は Home からも行えるが、この画面からも行えるようにする -->
        <Button
            Text="進捗レポートを見る"
            Clicked="OnOpenProgressReportClicked"
            HorizontalOptions="Fill" />

        <ScrollView>
            <CollectionView
                    ItemsSource="{Binding TodayItems}"
                    Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Stroke="#ccc"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <!-- 左: 習慣名と色インジケータ -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <BoxView
                                            HeightRequest="4"
                                            WidthRequest="80"
                                            Color="{Binding Habit.ColorHex}"
                                            CornerRadius="2"
                                            HorizontalOptions="Start" />
                                        <Label
                                            Text="{Binding Habit.Name}"
                                            FontSize="16"
                                            VerticalOptions="Center"
                                            HorizontalOptions="StartAndExpand" />
                                    </VerticalStackLayout>
                                    <!-- 右: チェックボタン（達成/未達成のトグル） -->
                                    <Button
                                        Grid.Column="1"
                                        Text="{Binding IsCheckedToday, Converter={StaticResource BoolToStatusTextConverter}}"
                                        Command="{Binding BindingContext.ToggleCheckCommand, Source={x:Reference TodayTasksPageRoot}}"
                                        CommandParameter="{Binding .}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- 習慣が0件のときのメッセージ -->
        <Label
            x:Name="EmptyMessageLabel"
            Text="習慣が登録されていません。習慣はマスタで追加してください。"
            IsVisible="False"
            FontSize="14"
            TextColor="Gray"
            HorizontalOptions="Center"
            Margin="0,20,0,0" />

    </VerticalStackLayout>

</ContentPage>
