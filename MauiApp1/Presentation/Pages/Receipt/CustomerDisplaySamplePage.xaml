<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Presentation.Pages.Receipt.CustomerDisplaySamplePage"
             Title="カスタマーディスプレイ（DM-D30）">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,32"
            Spacing="16">
            <Label
                x:Name="PlatformHintLabel"
                FontSize="13"
                TextColor="{AppThemeBinding Light=#B00020, Dark=#FF8888}"
                IsVisible="False"
                Text="このサンプルは Windows（net10.0-windows）でのみ送信が動作します。" />
            <Label Text="接続方法は Windows プリンター固定です。環境依存設定の CustomerDisplay:WindowsPrinterName に登録したプリンターへ RAW で送信します。" />
            <Label Text="1 行目（最大 20 バイト相当・Shift_JIS）" />
            <Entry
                x:Name="Line1Entry"
                Placeholder="Welcome"
                Text="いらっしゃいませ"
                HorizontalOptions="Fill" />
            <Label Text="2 行目" />
            <Entry
                x:Name="Line2Entry"
                Placeholder="Thank you"
                Text="ありがとうございました"
                HorizontalOptions="Fill" />
            <Button
                x:Name="SendButton"
                Text="ディスプレイに送る"
                Clicked="OnSendClicked"
                HorizontalOptions="Fill" />
            <Label
                FontSize="13"
                TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                Text="送信内容は ESC @（初期化）のあと、1 行目・LF（0x0A）・2 行目の順です。" />
            <Button
                Text="サンプル文言に戻す"
                Clicked="OnResetSampleClicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
