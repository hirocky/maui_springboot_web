<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Presentation.Pages.Receipt.ReceiptPrintPage"
             Title="レシートプリンター（TM-T88V）">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,32"
            Spacing="16">
            <Label Text="Windows・APD5 想定の試験印字です。" />
            <Label Text="ロゴ（任意）" FontAttributes="Bold" />
            <Label
                FontSize="13"
                TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                Text="印刷の一番上に表示する画像。Windows ではローカルのファイルパスを指定するか「参照」で選びます（PNG/JPG/BMP など）。空欄ならロゴなし。" />
            <HorizontalStackLayout Spacing="8">
                <Entry
                    x:Name="LogoPathEntry"
                    Placeholder="例: C:\data\logo.png"
                    HorizontalOptions="FillAndExpand" />
                <Button
                    Text="参照…"
                    Clicked="OnLogoPickClicked" />
            </HorizontalStackLayout>
            <Label Text="印字するテキスト" />
            <Editor
                x:Name="ReceiptTextEditor"
                Placeholder="ここに印字する文字列を入力"
                AutoSize="TextChanges"
                MinimumHeightRequest="100"
                HorizontalOptions="Fill" />
            <Label Text="プリンターは固定で利用します（環境依存設定の ReceiptPrinter:WindowsPrinterName）。" />
            <Button
                Text="印刷してカット"
                Clicked="OnReceiptPrintClicked"
                HorizontalOptions="Fill" />
            <Label
                FontSize="13"
                TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                Text="下のボタンは、添付サンプルに近い体裁のデモ領収書を印字します（上のエディタの内容は使いません）。" />
            <Button
                Text="サンプル領収書（快活CLUB形式）を印刷"
                Clicked="OnSampleKaikatsuReceiptClicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
