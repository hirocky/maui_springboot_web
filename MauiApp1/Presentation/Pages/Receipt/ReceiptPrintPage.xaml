<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Presentation.Pages.Receipt.ReceiptPrintPage"
             Title="レシート印刷">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,32"
            Spacing="16">
            <Label Text="Windows・APD5 想定の試験印字です。" />
            <Label Text="印字するテキスト" />
            <Editor
                x:Name="ReceiptTextEditor"
                Placeholder="ここに印字する文字列を入力"
                AutoSize="TextChanges"
                MinimumHeightRequest="100"
                HorizontalOptions="Fill" />
            <Label Text="プリンター" FontAttributes="Bold" />
            <Label
                FontSize="13"
                TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                Text="Windows の「設定」→「Bluetooth とデバイス」→「プリンターとスキャナー」に表示されている名前と同じものが、下の一覧に出ます。迷ったら「既定のプリンター」を選ぶか、設定で TM を既定にしてください。" />
            <Picker
                x:Name="PrinterPicker"
                Title="一覧から選ぶ" />
            <Label
                FontSize="13"
                TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                Text="一覧に無いときだけ（任意）" />
            <Entry
                x:Name="ReceiptPrinterNameEntry"
                Placeholder="空欄でよい。ここに入力すると一覧より優先されます。"
                HorizontalOptions="Fill" />
            <Button
                Text="印刷してカット"
                Clicked="OnReceiptPrintClicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
